# Variables de entorno para Docker Compose
# Copia este archivo a .env y configura los valores según necesites

# Secreto para firmar tokens JWT (GENERADO PARA PRODUCCIÓN)
# Este valor es seguro y aleatorio. No compartirlo.
JWT_SECRET=8a4ba4e697aef510a2bb2fc7ecd75f328c4b0b9fb7178e9392fa39de7ddb2ba0e52eeab8a694d7a3493ad0b49a6be4df67f9aa2375625988ef15f1683b11ede8

# URL del frontend (para CORS)
# En producción, cambia esto a tu dominio real, ej: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173

# Configuración de base de datos (opcional, ya tiene defaults en docker-compose.yml)
DB_HOST=db
DB_PORT=5432
DB_NAME=hormigoncalc
DB_USER=postgres
DB_PASSWORD=postgres
